# Odoo API base URL. REQUIRED when Vite proxy is disabled (direct CORS).
# Set this so axios calls Odoo at http://127.0.0.1:8076
# VITE_API_BASE=http://127.0.0.1:8076
# VITE_API_BASE=http://dash-analytics.febnotech.com
# Optional: used only when Vite proxy is enabled (proxy block uncommented in vite.config.js)
# VITE_ODOO_URL=http://127.0.0.1:8076
